SUPABASE_URL=http://127.0.0.1:54321
SERVICE_ROLE_KEY=<service-role-key>
JWT_SIGNING_SECRET=<jwt-signing-secret>

# Optional — enable real TeamUp OAuth (all four required together).
# When unset, token-broker keeps the existing POST stub path only.
# TEAMUP_OAUTH_CLIENT_ID=<teamup-oauth-client-id>
# TEAMUP_OAUTH_CLIENT_SECRET=<teamup-oauth-client-secret>
# TEAMUP_OAUTH_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/token-broker?oauth=callback
# TEAMUP_OAUTH_PROVIDER_ID=<teamup-provider-id>
# TEAMUP_OAUTH_SUCCESS_REDIRECT_URI=https://<app-host>/auth/callback
# TEAMUP_OAUTH_SCOPE=read_write provider:<teamup-provider-id>
# TEAMUP_OAUTH_AUTHORIZE_URL=https://goteamup.com/api/v2/auth/oauth/authorize
# TEAMUP_OAUTH_TOKEN_URL=https://goteamup.com/api/v2/auth/oauth/token
