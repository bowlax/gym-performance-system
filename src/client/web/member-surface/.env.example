# GymPerformance member web surface — local development
# Copy to .env.local and fill in values (do not commit .env.local).

# Supabase project API URL (e.g. https://<project-ref>.supabase.co)
GYMPERF_SUPABASE_URL=

# Supabase publishable (anon) key — safe for client-side use; RLS enforces access
GYMPERF_SUPABASE_PUBLISHABLE_KEY=

# Stub broker test member UUID (pre-release only; replace with real TeamUp auth)
TEST_DEVICE_MEMBER_ID=
